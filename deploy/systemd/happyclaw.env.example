# HappyClaw environment overrides (optional)
#
# Copy to:
#   - system service: /etc/happyclaw/happyclaw.env
#   - user service:   ~/.config/happyclaw/happyclaw.env

# Cookie/security mode
#
# HappyClaw uses NODE_ENV=production to set a Secure session cookie.
# If you access via plain HTTP (e.g. http://localhost:3100), browsers will NOT
# persist Secure cookies and login may appear "broken".
#
# - Local HTTP: leave NODE_ENV unset
# - HTTPS behind reverse-proxy: set NODE_ENV=production (recommended)
# NODE_ENV=production

# Web/API port (default: 3100)
WEB_PORT=3100

# When behind nginx/caddy/cloudflare, set to true to trust X-Forwarded-For
TRUST_PROXY=false

# Timezone for scheduled tasks (cron). Defaults to system timezone.
# TZ=Asia/Shanghai

# Log level: trace | debug | info | warn | error | fatal
# LOG_LEVEL=info
